# Nexo visual test: textured octahedron
mtllib test_model.mtl

o metallic_grid
v 0.5 1.0 0.5
v 0.5 0.0 0.5
v 0.5 0.5 0.0
v 1.0 0.5 0.5
v 0.5 0.5 1.0
v 0.0 0.5 0.5

vt 0.5 1.0
vt 0.0 0.0
vt 1.0 0.0

usemtl metallic_grid
s off
f 3/2 1/1 4/3
f 4/2 1/1 5/3
f 5/2 1/1 6/3
f 6/2 1/1 3/3
f 3/2 4/3 2/1
f 4/2 5/3 2/1
f 5/2 6/3 2/1
f 6/2 3/3 2/1
